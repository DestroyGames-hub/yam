<!-- ===== AndroidManifest.xml Tema Referansı ===== -->
<!--
    styles.xml'de tanımlanan temaları AndroidManifest.xml'de kullanmak için:

    <application
        ...
        android:theme="@style/Theme.YAMChat"
        ...
    >
        <activity
            android:name=".MainActivity"
            android:theme="@style/Theme.YAMChat"
        >
        </activity>
    </application>

    Night Mode (Karanlık Tema) için:
    res/values-night/styles.xml oluştur ve
    Theme.YAMChat.Dark stilini kullan.
-->

