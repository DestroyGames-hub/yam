<!-- ===== res/values/styles.xml ===== -->
<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Light Theme -->
    <style name="Theme.YAMChat" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        
        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightNavigationBar">true</item>
        
        <!-- Renkler -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/primary</item>
        
        <!-- Arka Plan -->
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        
        <!-- Yazı Tipleri -->
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
    </style>
    
    <!-- Dark Theme -->
    <style name="Theme.YAMChat.Dark" parent="Theme.AppCompat.NoActionBar">
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:windowBackground">@color/surface_dark</item>
    </style>
    
    <!-- Buton Stilleri -->
    <style name="Widget.YAMChat.Button" parent="Widget.AppCompat.Button.Colored">
        <item name="android:textColor">@color/surface</item>
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">12dp</item>
    </style>
    
    <!-- EditText Stilleri -->
    <style name="Widget.YAMChat.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:padding">12dp</item>
    </style>
    
    <!-- Bildirim Stilleri -->
    <style name="Widget.YAMChat.NotificationText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>

